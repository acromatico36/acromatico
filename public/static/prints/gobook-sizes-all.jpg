	<script>
		function inIframe () {
		try {
			return window.self !== window.top;
		} catch (e) {
			return true;
		}
		}
		setTimeout(() => {
		if(inIframe ()){
			console.log("In Iframe");
			Array.from(document.querySelectorAll('a[target="_blank"]'))
			.forEach(link => link.removeAttribute('target'));
			document.querySelector("#cookiescript_injected").style.display = "none";
		}
		}, 1500);
		if(inIframe ()){
			document.querySelector("body").appendChild("<style>#cookiescript_injected{display: none!important;}</style>")
		}
	</script>
