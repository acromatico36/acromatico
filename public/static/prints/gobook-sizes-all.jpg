        var l_pub='en';
        var array_footer_links=['privacy_footer','cookie_footer','copyrights_footer'];
        jQuery.each(array_footer_links, function(index, value) {
            if(jQuery('#'+value).length) {
                var tmp_href=jQuery('#'+value).attr('href');
                tmp_href = tmp_href.replace("/en/", "/"+l_pub+"/");
                jQuery('#'+value).attr("href",tmp_href);
            }
        });

        if (jQuery('#tradearea_link').length) {
            var tmp_href=jQuery('#tradearea_link').attr('href');
            var tmp_l_pub=l_pub;
            if (tmp_l_pub=="en") tmp_l_pub="us";
            tmp_href = tmp_href.replace("lin=en", "lin="+tmp_l_pub);
            jQuery('#tradearea_link').attr("href",tmp_href);
        }
    });
