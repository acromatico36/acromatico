rent-menu-item a { color: #9c7a58 !important; background-color: #dddddd !important; } /* Header General */ #search-btn, #shopping-btn, #close-search-btn { color: #eae6df; } #search-btn:hover, #shopping-btn:hover, #close-search-btn:hover { color: #d4c8be; } #slogan{ font: 400 20px Open Sans, Arial, Helvetica, sans-serif; color: #777777; margin-top: 26px; } /* Mobile Header */ #mobile-navigation{ background: #eae6df; } #mobile-navigation ul li a{ font: 400 14px Poppins, Arial, Helvetica, sans-serif; color: #2d2d2b; border-bottom-color: #d4c8be !important; } #mobile-navigation ul li a:hover, #mobile-navigation ul li a:hover [class^='fa-'], #mobile-navigation li.open > a, #mobile-navigation ul li.current-menu-item > a, #mobile-navigation ul li.current-menu-ancestor > a{ color: #9c7a58; } body #mobile-navigation li.open > a [class^='fa-']{ color: #9c7a58; } #mobile-navigation form, #mobile-navigation form input{ background: #444444; color: #cccccc; } #mobile-navigation form:before{ color: #cccccc; } #mobile-header{ background: #ffffff; height: 90px; } #mobile-navigation-btn, #mobile-cart-btn, #mobile-shopping-btn{ color: #eae6df; line-height: 90px; } #mobile-navigation-btn:hover, #mobile-cart-btn:hover, #mobile-shopping-btn:hover { color: #d4c8be; } #mobile-header .logo{ margin-top: 20px; } /* Header V1 */ #header.header-v1 { height: 90px; background: #ffffff; } .header-v1 .logo{ margin-top: 20px; } .header-v1 #navigation > ul > li{ height: 90px; padding-top: 35px; } .header-v1 #navigation .sub-menu{ top: 90px; } .header-v1 .header-icons-divider{ line-height: 90px; background: #efefef; } #header.header-v1 .widget_shopping_cart{ top: 90px; } .header-v1 #search-btn, .header-v1 #close-search-btn, .header-v1 #shopping-btn{ line-height: 90px; } .header-v1 #search-top, .header-v1 #search-top input{ height: 90px; } .header-v1 #search-top input{ color: #666666; font-family: Poppins, Arial, Helvetica, sans-serif; } /* Header V3 */ #header.header-v3 { background: #ffffff; } .heade