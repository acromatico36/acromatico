        }
        
        .ast-mobile-popup-overlay.active {
            opacity: 1;
            visibility: visible;
        }
        
        .content-container {
            max-width: 1240px;
            margin: 0 auto;
            padding: 80px 20px;
        }
        
        .post-title {
            font-size: 44px;
            font-weight: 400;
            color: #2a2a2a;
            letter-spacing: -0.5px;
            margin-bottom: 30px;
            text-align: center;
            line-height: 1.4em;
        }
        
        .post-intro {
            font-size: 16px;
            line-height: 1.8;
            color: #3a3a3a;
            margin-bottom: 50px;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }
        
        .gallery-container {
            column-count: 2;
            column-gap: 10px;
            margin-bottom: 60px;
        }
        
        @media (max-width: 768px) {
            .gallery-container {
                column-count: 1;
            }
            
            .hero-title {
                font-size: 36px;
                padding: 0 20px;
            }
            
            .post-title {
                font-size: 30px;
            }
        }
        
        .gallery-item {
            break-inside: avoid;
            margin-bottom: 10px;
            display: block;
        }
        
        .gallery-image {
            width: 100%;
            height: auto;
            display: block;
            cursor: pointer;
            transition: opacity 0.3s ease;
            border-radius: 10px;
            overflow: hidden;
        }
        
        .gallery-image:hover {
            opacity: 0.9;
        }
        
        .section-heading {
            font-size: 32px;
            font-weight: 400;
            color: #2a2a2a;
            letter-spacing: -0.3px;
            margin: 80px 0 30px 0;
            padding-top: 60px;
            text-align: center;
            line-height: 1.3em;
            border-top: 1px solid #e0e0e0;
        }
        
        .section-heading:first-of-type {
            border-top: none;
            padding-top: 0;
