            background-size: cover;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .hero-section::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.35);
        }
        
        .hero-title {
            position: relative;
            z-index: 10;
            color: #ffffff;
            font-size: 56px;
            font-weight: 300;
            text-align: center;
            letter-spacing: -0.5px;
            line-height: 1.3em;
            max-width: 900px;
            padding: 0 40px;
