        .site-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 9999;
            padding: 20px 40px;
            display: flex;
            justify-content: center;
            align-items: center;
            background: transparent;
        }
        
        .site-logo {
            max-width: 200px;
            height: auto;
            filter: brightness(0) invert(1);
