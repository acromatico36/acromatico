})();
</script>
<!-- GLightbox JavaScript -->
<script src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
<script>
    // Initialize GLightbox for gallery
    const lightbox = GLightbox({
        touchNavigation: true,
        loop: true,
        autoplayVideos: true,
        closeButton: true,
        openEffect: 'zoom',
        closeEffect: 'fade',
        slideEffect: 'slide'
    });
</script>
