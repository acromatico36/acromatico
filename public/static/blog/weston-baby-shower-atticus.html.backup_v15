            border-radius: 50%;
            object-fit: cover;
            border: 5px solid #ffffff;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .author-bio img:hover {
            transform: scale(1.1);
            box-shadow: 0 12px 30px rgba(255,255,255,0.3);
            border-color: #f0f0f0;
        }
        
        .author-info h3 {
            font-size: 26px;
