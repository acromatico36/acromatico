            margin-bottom: 15px;
        }
        
        .author-info a {
            color: #ffffff;
            text-decoration: none;
            font-weight: 600;
            margin-right: 15px;
            border-bottom: 2px solid rgba(255,255,255,0.3);
            transition: border-color 0.3s ease;
        }
        
        .author-info a:hover {
            border-bottom-color: #ffffff;
        }
        
        .author-info a:hover {
            text-decoration: underline;
        }
        
        /* Related Posts */
        .related-posts {
            margin: 60px 0;
        }
        
        .related-posts h2 {
            font-size: 32px;
            text-align: center;
            margin-bottom: 40px;
            color: #3a3a3a;
        }
        
        .related-posts-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        /* Force 3 columns on desktop */
        @media (min-width: 769px) {
            .related-posts-grid {
                grid-template-columns: repeat(3, 1fr) !important;
            }
        }
        
        .related-post {
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transition: all 0.4s ease;
        }
        
        .related-post:hover {
