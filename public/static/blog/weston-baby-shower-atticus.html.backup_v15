        }
        
        /* Author Bio */
        /* Author Bio */
        .author-bio {
            background: linear-gradient(135deg, #2d2d2d 0%, #1a1a1a 100%);
            padding: 50px;
            border-radius: 12px;
            margin: 60px 0;
            display: flex;
            align-items: center;
            gap: 40px;
        }
        
        .author-headshots {
            display: flex;
            flex-direction: column;
            gap: 15px;
            flex-shrink: 0;
        }
        
        .author-bio img {
            width: 150px;
