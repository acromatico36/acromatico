        }
        
        /* Author Bio */
        /* Author Bio */
        .author-bio {
            background: linear-gradient(135deg, #2d2d2d 0%, #1a1a1a 100%);
            padding: 50px;
            border-radius: 12px;
            margin: 60px 0;
            display: flex;
            align-items: center;
            gap: 40px;
        }
        
        .author-headshots {
            display: flex;
            flex-direction: column;
            gap: 15px;
            flex-shrink: 0;
        }
        
        .author-bio img {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            border: 5px solid #ffffff;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .author-bio img:hover {
            transform: scale(1.1);
            box-shadow: 0 12px 30px rgba(255,255,255,0.3);
            border-color: #f0f0f0;
        }
        
        .author-info h3 {
            font-size: 26px;
            font-weight: 400;
            color: #ffffff;
            margin-bottom: 15px;
            letter-spacing: -0.2px;
        }
        
        .author-info p {
