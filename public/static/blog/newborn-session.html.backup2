        }
        
        /* CTA Sections */
        .cta-section {
            background: linear-gradient(135deg, #1a1a1a 0%, #4a4a4a 100%);
            padding: 60px 40px;
            text-align: center;
            border-radius: 12px;
            margin: 60px 0;
            color: #ffffff;
