            text-decoration: none;
            transition: color 0.3s;
        }
        
        .vendor-credits a:hover {
            color: #5a6609;
            text-decoration: underline;
        }
        
        /* FAQ Section */
        .faq-section {
            margin: 60px 0;
        }
        
        .faq-item {
            background: #f9f9f9;
            padding: 30px;
            margin-bottom: 20px;
