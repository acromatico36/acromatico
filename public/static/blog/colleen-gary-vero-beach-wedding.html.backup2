        }
        
        .main-header-menu .menu-link:hover {
            color: #4794A6;
        }
        
        .ast-mobile-popup-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            z-index: 9997;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s ease, visibility 0.3s ease;
        }
        
        .ast-mobile-popup-overlay.active {
            opacity: 1;
            visibility: visible;
        }
        
        .content-container {
            max-width: 1240px;
            margin: 0 auto;
            padding: 80px 20px;
        }
        
        .post-title {
            font-size: 44px;
            font-weight: 400;
            color: #2a2a2a;
            letter-spacing: -0.5px;
            margin-bottom: 30px;
            text-align: center;
            line-height: 1.4em;
        }
        
        .post-intro {
            font-size: 16px;
            line-height: 1.8;
            color: #3a3a3a;
            margin-bottom: 50px;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }
        
        .gallery-container {
            column-count: 2;
            column-gap: 10px;
            margin-bottom: 60px;
        }
        
        @media (max-width: 768px) {
            .gallery-container {
                column-count: 1;
            }
            
            .hero-title {
                font-size: 36px;
                padding: 0 20px;
            }
            
            .post-title {
                font-size: 30px;
            }
        }
        
        .gallery-item {
            break-inside: avoid;
            margin-bottom: 10px;
            display: block;
        }
        
        .gallery-image {
            width: 100%;
            height: auto;
            display: block;
            cursor: pointer;
            transition: opacity 0.3s ease;
            border-radius: 10px;
            overflow: hidden;
        }
        
        .gallery-image:hover {
            opacity: 0.9;
        }
        
        .section-heading {
            font-size: 32px;
            font-weight: 400;
            color: #2a2a2a;
            letter-spacing: -0.3px;
            margin: 80px 0 30px 0;
            padding-top: 60px;
            text-align: center;
            line-height: 1.3em;
            border-top: 1px solid #e0e0e0;
        }
        
        .section-heading:first-of-type {
            border-top: none;
            padding-top: 0;
            margin-top: 60px;
        }
        
        .section-text {
            font-size: 16px;
            line-height: 1.8;
            color: #3a3a3a;
            margin-bottom: 40px;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }
        
        /* Featured Section Images */
        .featured-image {
            max-width: 1000px;
            margin: 50px auto 60px auto;
            text-align: center;
        }
        
        .section-image {
            width: 100%;
            height: auto;
            display: block;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        }
        
        .image-caption {
            font-size: 14px;
            line-height: 1.6;
            color: #666666;
            font-style: italic;
            margin-top: 15px;
            padding: 0 20px;
            text-align: center;
        }
        
        /* CTA Sections */
        .cta-section {
            background: linear-gradient(135deg, #1a1a1a 0%, #4a4a4a 100%);
            padding: 60px 40px;
            text-align: center;
            border-radius: 12px;
            margin: 60px 0;
            color: #ffffff;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        
        .cta-section h2, .cta-section h3 {
            color: #ffffff;
            margin-bottom: 20px;
            font-size: 34px;
            font-weight: 400;
            letter-spacing: -0.3px;
        }
        
        .cta-section p {
            font-size: 18px;
            line-height: 1.6;
            margin-bottom: 30px;
            color: rgba(255, 255, 255, 0.95);
        }
        
        .cta-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
        }
        
        .cta-button {
            display: inline-block;
            padding: 12px 24px;
            background: #ffffff;
            color: #1a1a1a;
            text-decoration: none;
            border-radius: 50px;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            margin: 0 8px;
            border: 2px solid #ffffff;
            position: relative;
            overflow: hidden;
            min-width: auto;
            max-width: fit-content;
            white-space: nowrap;
        }
        
        .cta-button::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.5s ease;
        }
        
        .cta-button:hover::before {
            left: 100%;
        }
        
        .cta-button:hover {
            transform: translateY(-5px) scale(1.05);
            box-shadow: 0 15px 40px rgba(0,0,0,0.4);
            background: #f0f0f0;
        }
        
        .cta-button.secondary {
            background: transparent;
            color: #ffffff;
            border: 2px solid #ffffff;
        }
        
        .cta-button.secondary:hover {
            background: #ffffff;
            color: #1a1a1a;
            transform: translateY(-5px) scale(1.05);
            box-shadow: 0 15px 40px rgba(255,255,255,0.3);
        }
        
        /* Vendor Credits */
        .vendor-credits {
            background: #f8f8f8;
            padding: 40px;
            border-radius: 8px;
            margin: 40px 0;
        }
        
        .vendor-credits ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        
        .vendor-credits li {
            padding: 12px 0;
            border-bottom: 1px solid #e0e0e0;
            font-size: 15px;
        }
        
        .vendor-credits li:last-child {
            border-bottom: none;
        }
        
        .vendor-credits a {
            color: #4794A6;
            text-decoration: none;
            transition: color 0.3s;
        }
        
        .vendor-credits a:hover {
            color: #5a6609;
            text-decoration: underline;
        }
        
        /* FAQ Section */
        .faq-section {
            margin: 60px 0;
        }
        
        .faq-item {
            background: #f9f9f9;
            padding: 30px;
            margin-bottom: 20px;
            border-radius: 8px;
            border-left: 4px solid #4794A6;
        }
        
        .faq-question {
            font-size: 20px;
            font-weight: 500;
            color: #2a2a2a;
            margin-bottom: 15px;
        }
        
        .faq-answer p {
            font-size: 15px;
            line-height: 1.8;
            color: #555;
            margin: 0;
        }
        
        /* Author Bio */
        /* Author Bio */
        .author-bio {
            background: linear-gradient(135deg, #2d2d2d 0%, #1a1a1a 100%);
            padding: 50px;
            border-radius: 12px;
            margin: 60px 0;
            display: flex;
            align-items: center;
            gap: 40px;
        }
        
        .author-headshots {
            display: flex;
            flex-direction: column;
            gap: 15px;
            flex-shrink: 0;
        }
        
        .author-bio img {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            border: 5px solid #ffffff;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .author-bio img:hover {
            transform: scale(1.1);
            box-shadow: 0 12px 30px rgba(255,255,255,0.3);
            border-color: #f0f0f0;
        }
        
        .author-info h3 {
            font-size: 26px;
            font-weight: 400;
            color: #ffffff;
            margin-bottom: 15px;
            letter-spacing: -0.2px;
        }
        
        .author-info p {
            font-size: 15px;
            line-height: 1.8;
            color: #e0e0e0;
            margin-bottom: 15px;
        }
        
        .author-info a {
            color: #ffffff;
            text-decoration: none;
            font-weight: 600;
            margin-right: 15px;
            border-bottom: 2px solid rgba(255,255,255,0.3);
            transition: border-color 0.3s ease;
        }
        
        .author-info a:hover {
            border-bottom-color: #ffffff;
        }
        
        .author-info a:hover {
            text-decoration: underline;
        }
        
        /* Related Posts */
        .related-posts {
            margin: 60px 0;
        }
        
        .related-posts h2 {
            font-size: 32px;
            text-align: center;
            margin-bottom: 40px;
            color: #3a3a3a;
        }
        
        .related-posts-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        /* Force 3 columns on desktop */
        @media (min-width: 769px) {
            .related-posts-grid {
                grid-template-columns: repeat(3, 1fr) !important;
            }
        }
        
        .related-post {
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transition: all 0.4s ease;
        }
        
        .related-post:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.2);
        }
        
        .related-post img {
            width: 100%;
            height: 350px;
            object-fit: cover;
            transition: transform 0.4s ease;
        }
        
        .related-post:hover img {
