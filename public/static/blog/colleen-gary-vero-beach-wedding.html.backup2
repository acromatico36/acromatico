            text-decoration: none;
            margin: 0 15px;
            font-size: 14px;
            transition: color 0.3s;
        }
        
        .footer-nav a:hover {
            color: #4794A6;
        }
        
        /* Mobile Responsive */
        @media (max-width: 768px) {
            .author-bio {
                flex-direction: column;
                text-align: center;
            }
            
            .author-headshots {
                align-items: center;
            }
            
            .author-bio img {
                width: 120px;
