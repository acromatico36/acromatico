        }
        
        .main-header-menu .menu-item {
            margin-bottom: 25px;
        }
        
        .main-header-menu .menu-link {
            text-decoration: none;
            color: #3a3a3a;
            font-size: 16px;
            font-weight: 600;
            transition: color 0.3s;
