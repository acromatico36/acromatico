            margin-top: 10px;
        }
        
        .search-results.active {
            display: block;
        }
        
        .search-result-item {
            padding: 15px 20px;
            border-bottom: 1px solid #f0f0f0;
            cursor: pointer;
            transition: background 0.2s ease;
        }
        
        .search-result-item:last-child {
            border-bottom: none;
