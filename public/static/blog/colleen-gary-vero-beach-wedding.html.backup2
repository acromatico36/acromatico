        }
        
        .related-post h3 {
            padding: 20px;
            font-size: 18px;
            background: #ffffff;
        }
        
        .related-post a {
            text-decoration: none;
            color: #3a3a3a;
        }
        
        .related-post a:hover {
            color: #4794A6;
        }
        
        /* Footer */
        .post-footer {
            background: #2a2a2a;
