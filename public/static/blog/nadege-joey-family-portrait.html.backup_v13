        }
        
        .faq-answer p {
            font-size: 15px;
            line-height: 1.8;
            color: #555;
            margin: 0;
        }
        
        /* Author Bio */
        /* Author Bio */
        .author-bio {
            background: linear-gradient(135deg, #2d2d2d 0%, #1a1a1a 100%);
            padding: 50px;
            border-radius: 12px;
            margin: 60px 0;
            display: flex;
            align-items: center;
            gap: 40px;
        }
        
        .author-headshots {
            display: flex;
            flex-direction: column;
            gap: 15px;
            flex-shrink: 0;
        }
        
        .author-bio img {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            border: 5px solid #ffffff;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .author-bio img:hover {
            transform: scale(1.1);
            box-shadow: 0 12px 30px rgba(255,255,255,0.3);
            border-color: #f0f0f0;
        }
        
        .author-info h3 {
            font-size: 26px;
            font-weight: 400;
            color: #ffffff;
            margin-bottom: 15px;
            letter-spacing: -0.2px;
        }
        
        .author-info p {
            font-size: 15px;
            line-height: 1.8;
            color: #e0e0e0;
            margin-bottom: 15px;
        }
        
        .author-info a {
            color: #ffffff;
            text-decoration: none;
            font-weight: 600;
            margin-right: 15px;
            border-bottom: 2px solid rgba(255,255,255,0.3);
            transition: border-color 0.3s ease;
        }
        
        .author-info a:hover {
            border-bottom-color: #ffffff;
        }
        
        .author-info a:hover {
            text-decoration: underline;
        }
        
        /* Related Posts */
        .related-posts {
            margin: 60px 0;
        }
        
        .related-posts h2 {
            font-size: 32px;
            text-align: center;
            margin-bottom: 40px;
            color: #3a3a3a;
        }
        
        .related-posts-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        /* Force 3 columns on desktop */
        @media (min-width: 769px) {
            .related-posts-grid {
                grid-template-columns: repeat(3, 1fr) !important;
            }
        }
        
        .related-post {
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transition: all 0.4s ease;
        }
        
        .related-post:hover {
