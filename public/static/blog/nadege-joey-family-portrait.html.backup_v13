            margin-left: auto;
            margin-right: auto;
        }
        
        /* Featured Section Images */
        .featured-image {
            max-width: 1000px;
            margin: 50px auto 60px auto;
            text-align: center;
        }
        
        .section-image {
            width: 100%;
            height: auto;
            display: block;
